# Copy to .env and fill in for local runs. Never commit .env.
# In production these are set via fly.toml [env] (non-secret) and `fly secrets` (secret).

# --- Routing (non-secret) ---
GUILD_ID=000000000000000000        # discord server id
ADMIN_ROLE_ID=000000000000000000   # role allowed to run /link and /sync-roles
GITHUB_ORG=ranqialabs              # github org slug

# JSON maps. github team slug -> discord role id
TEAM_TO_ROLE={"engineering":000000000000000000,"design":000000000000000000}
# "owner/repo" -> discord channel id
REPO_TO_CHANNEL={"ranqialabs/workspace":000000000000000000}

# --- Secrets ---
DISCORD_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=            # PEM contents, or a path to the .pem file
GITHUB_WEBHOOK_SECRET=

# --- Network (optional, defaults shown) ---
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

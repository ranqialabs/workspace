# Copy to .env for local runs. Never commit .env.
# In production: GITHUB_ORG lives in fly.toml [env]; secrets via `fly secrets`.

# --- Non-secret ---
GITHUB_ORG=ranqialabs

# --- Secrets ---
DISCORD_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=            # PEM contents, or a path to the .pem file
GITHUB_WEBHOOK_SECRET=

# --- Network (optional, defaults shown) ---
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
